# Keycloak Client Secrets
# Copy the client secret from quarkus-mcp-client in Keycloak (Step 2.2)
export QUARKUS_MCP_CLIENT_SECRET=your-mcp-client-secret-here

# Copy the client secret from quarkus-mcp-server in Keycloak (Step 2.3)
export QUARKUS_MCP_SERVER_SECRET=your-mcp-server-secret-here

# OpenAI API Key
# Get this from https://platform.openai.com/api-keys
export OPENAI_API_KEY=sk-your-openai-api-key-here
